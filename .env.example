# Copy to `.env.local` for local development (single local env file; do not commit).
#
# Authorizer demo (required for a working login widget; build uses safe fallbacks)
NEXT_PUBLIC_AUTHORIZER_URL=
NEXT_PUBLIC_REDIRECT_URL=
NEXT_PUBLIC_AUTHORIZER_CLIENT_ID=

# Canonical URL for SEO (optional; default https://authorizer.dev)
NEXT_PUBLIC_SITE_URL=https://authorizer.dev

# Google Analytics (optional; uses gtag when set)
NEXT_PUBLIC_GOOGLE_ANALYTICS_KEY=
